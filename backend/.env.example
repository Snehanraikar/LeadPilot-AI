# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/postgres

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate unique secrets with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-a-random-32+-char-secret
JWT_REFRESH_SECRET=replace-with-a-different-random-32+-char-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Options: groq | ollama | openai
# groq   = FREE cloud LLM (14,400 req/day). Get key at console.groq.com — no card needed.
# ollama = FREE local LLM. Run: ollama pull llama3.1 && ollama pull nomic-embed-text
# openai = Paid OpenAI API

AI_PROVIDER=groq

# Groq (recommended free option)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# HuggingFace — free embeddings used with Groq provider
# Get key at huggingface.co/settings/tokens (free account, no card)
HF_API_KEY=
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# pgvector size must match embedding model:
#   384  → BAAI/bge-small-en-v1.5 (HF) or nomic-embed-text (Ollama)
#   1536 → text-embedding-3-small (OpenAI)
VECTOR_SIZE=384

# OpenAI (paid)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (local, fully free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── PostHog ──────────────────────────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
EMAIL_FROM=noreply@leadpilot.ai
